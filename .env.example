# ---- Copy to .env; install.sh can generate this — never commit .env with secrets. ----
#
# Public hostname (no scheme). Used by Nginx and Let's Encrypt.
DOMAIN=lab.example.com

# PostgreSQL (Django; Flask uses local SQLite under /app/data in container)
POSTGRES_USER=lab
POSTGRES_DB=lab
POSTGRES_PASSWORD=change_me_strong
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-to-50-random-chars
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
# Optional Redis URL (reserved for app wiring)
REDIS_URL=redis://redis:6379/0

# Optional Telegram / lab — see README in repo
# DEMO_TELEGRAM_BOT_TOKEN=
# DEMO_TELEGRAM_CHAT_ID=

# Cloudflare not stored here: use deploy/secrets/cf.ini (API token) for install.sh
