# Render with:  DOMAIN=example.com envsubst '$DOMAIN' < this > /etc/nginx/sites-available/educational_demo
# Native install: Gunicorn listens on a Unix socket (see install-native.sh).

server {
    listen 80;
    listen [::]:80;
    server_name ${DOMAIN};

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ${DOMAIN};

    ssl_certificate /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 25m;

    location / {
        include proxy_params;
        proxy_pass http://unix:/run/educational_demo/gunicorn.sock;
    }
}
